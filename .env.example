# dzpokerV3 环境变量示例
# 复制为 .env 并按实际环境修改：cp .env.example .env
# 配置含义见 config.py 与 DEPLOYMENT.md

# ==================== 应用 ====================
SECRET_KEY=your_secret_key_here_use_openssl_rand_hex_32
FLASK_DEBUG=0

# ==================== MySQL（与 config.py 一致）====================
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=your_password
MYSQL_DATABASE=dzpoker
MYSQL_CHARSET=utf8mb4

# ==================== 游戏 ====================
PLAYER_ACTION_TIMEOUT=15
PLAYER_ACTION_TIMEOUT_MIN=10
PLAYER_ACTION_TIMEOUT_MAX=30

# ==================== 可选 ====================
# 若通过 systemd/gunicorn 或命令行指定端口可忽略
# PORT=5001
# HOST=0.0.0.0

# Figma 导出（仅本地跑 figma_export.py 时需要）
# FIGMA_ACCESS_TOKEN=
# FIGMA_FILE_KEY=
