# 生产环境配置示例
# 复制此文件为 .env 并修改相应的值

# ==================== 数据库配置 ====================
DB_HOST=localhost
DB_PORT=3306
DB_USER=dzpoker
DB_PASSWORD=your_secure_password_here
DB_NAME=dzpoker

# ==================== 服务器配置 ====================
FLASK_ENV=production
SECRET_KEY=your_secret_key_here_use_openssl_rand_hex_32
PORT=5002
HOST=0.0.0.0

# ==================== 游戏配置 ====================
PLAYER_ACTION_TIMEOUT=15
PLAYER_ACTION_TIMEOUT_MIN=10
PLAYER_ACTION_TIMEOUT_MAX=30

# ==================== 日志配置 ====================
LOG_LEVEL=INFO
LOG_FILE=/var/log/dzpoker/app.log

# ==================== Redis 配置（可选）====================
# REDIS_HOST=localhost
# REDIS_PORT=6379
# REDIS_PASSWORD=

# ==================== 安全配置 ====================
# CORS_ORIGINS=https://yourdomain.com
# MAX_CONTENT_LENGTH=16777216  # 16MB

# ==================== Figma 导出（可选，仅本地跑 figma_export.py 时需要）====================
# FIGMA_ACCESS_TOKEN=your_figma_personal_access_token
# FIGMA_FILE_KEY=your_figma_file_key

# ==================== 性能配置 ====================
# WORKERS=4
# THREADS=2
# TIMEOUT=120
